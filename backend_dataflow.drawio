<mxfile>
  <diagram name="Backend Data Flow" id="flow1">
    <mxGraphModel dx="1600" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="BACKEND DATA FLOW - Smart Parking" style="text;html=1;fontSize=20;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- ========== LUỒNG 1: SENSOR (bên trái) ========== -->
        <mxCell id="flow1_label" value="LUỒNG 1: CẬP NHẬT Ô ĐỖ (Sensor)" style="text;html=1;fontSize=14;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#7c3aed;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="400" height="25" as="geometry"/>
        </mxCell>

        <!-- ESP32 Sensor -->
        <mxCell id="esp_sensor" value="ESP32 Sensor Board&#xa;Batch 8 ô / 5 giây" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="180" height="50" as="geometry"/>
        </mxCell>

        <!-- Gin Handler -->
        <mxCell id="sensor_handler" value="HTTP Handler&#xa;POST /parking-slots/sensor&#xa;Parse JSON batch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="190" width="180" height="55" as="geometry"/>
        </mxCell>

        <!-- Slot Cache -->
        <mxCell id="slot_cache" value="Slot Status Cache&#xa;(Go map + sync.RWMutex)&#xa;&#xa;Giữ trạng thái mới nhất&#xa;của MỌI ô đỗ trong RAM" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;size=12;" vertex="1" parent="1">
          <mxGeometry x="50" y="290" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- Compare -->
        <mxCell id="compare" value="So sánh&#xa;Cache vs Batch&#xa;&#xa;Lọc ra ô nào LỆCH" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="65" y="410" width="150" height="100" as="geometry"/>
        </mxCell>

        <!-- No change -->
        <mxCell id="no_change" value="Không lệch&#xa;→ BỎ QUA&#xa;(0 query DB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=10;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="260" y="430" width="110" height="55" as="geometry"/>
        </mxCell>

        <!-- Update cache -->
        <mxCell id="update_cache" value="Cập nhật Cache&#xa;(RAM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="75" y="550" width="130" height="40" as="geometry"/>
        </mxCell>

        <!-- Batch UPDATE DB -->
        <mxCell id="batch_update" value="Batch UPDATE&#xa;parking_slots&#xa;SET status = ?&#xa;WHERE mac + port" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="630" width="170" height="60" as="geometry"/>
        </mxCell>

        <!-- ParkingHub broadcast -->
        <mxCell id="hub_broadcast" value="ParkingHub.BroadcastToLot()&#xa;Push event từ RAM&#xa;→ WebTransport → Frontend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="730" width="170" height="55" as="geometry"/>
        </mxCell>

        <!-- Sensor flow arrows -->
        <mxCell id="s1" value="HTTP POST batch" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#7c3aed;fontColor=#7c3aed;fontSize=9;" edge="1" source="esp_sensor" target="sensor_handler" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s2" value="đọc cache" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;fontSize=9;" edge="1" source="sensor_handler" target="slot_cache" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666;" edge="1" source="slot_cache" target="compare" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s4" value="GIỐNG" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#999;fontColor=#999;fontSize=9;" edge="1" source="compare" target="no_change" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s5" value="LỆCH" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;fontColor=#d6b656;fontSize=9;fontStyle=1;" edge="1" source="compare" target="update_cache" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;" edge="1" source="update_cache" target="batch_update" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="s7" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0284c7;" edge="1" source="batch_update" target="hub_broadcast" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ========== LUỒNG 2: GATE RFID (bên phải) ========== -->
        <mxCell id="flow2_label" value="LUỒNG 2: XE VÀO/RA (Gate RFID + Camera)" style="text;html=1;fontSize=14;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#CC0000;" vertex="1" parent="1">
          <mxGeometry x="500" y="60" width="450" height="25" as="geometry"/>
        </mxCell>

        <!-- ESP32 Gate -->
        <mxCell id="esp_gate" value="ESP32 Gate Board&#xa;Camera + RFID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="100" width="180" height="50" as="geometry"/>
        </mxCell>

        <!-- Camera Handler -->
        <mxCell id="cam_handler" value="POST /iot/camera&#xa;{ gate_id, plate_number }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="190" width="160" height="45" as="geometry"/>
        </mxCell>

        <!-- RFID Handler -->
        <mxCell id="rfid_handler" value="POST /iot/rfid&#xa;{ gate_id, mac, rfid_uid }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="190" width="160" height="45" as="geometry"/>
        </mxCell>

        <!-- PlateCache -->
        <mxCell id="plate_cache" value="PlateCache&#xa;(Go map + Mutex)&#xa;&#xa;map[gateID] → biển số&#xa;TTL 5 phút, dùng 1 lần" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;size=12;" vertex="1" parent="1">
          <mxGeometry x="430" y="280" width="140" height="85" as="geometry"/>
        </mxCell>

        <!-- IoT Service -->
        <mxCell id="iot_svc" value="IoT Service&#xa;&#xa;1. Validate gate (active?)&#xa;2. Validate card (active?)&#xa;3. Peek biển số từ PlateCache&#xa;4. Kiểm tra trùng session/plate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="630" y="280" width="210" height="100" as="geometry"/>
        </mxCell>

        <!-- Decision: Entry or Exit -->
        <mxCell id="gate_type" value="Loại Gate?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="420" width="110" height="70" as="geometry"/>
        </mxCell>

        <!-- Entry flow -->
        <mxCell id="entry_block" value="handleEntry()&#xa;&#xa;1. Kiểm tra bãi còn chỗ&#xa;2. Consume plate từ cache&#xa;3. INSERT parking_sessions&#xa;   (card_uid, plate, lot_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="530" width="190" height="100" as="geometry"/>
        </mxCell>

        <!-- Exit flow -->
        <mxCell id="exit_block" value="handleExit()&#xa;&#xa;1. Tìm session active&#xa;2. So khớp biển số&#xa;3. Tính phí (5k/7k mỗi giờ)&#xa;4. Consume plate từ cache&#xa;5. UPDATE session (exit_time, fee)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="530" width="200" height="115" as="geometry"/>
        </mxCell>

        <!-- Wallet deduct -->
        <mxCell id="wallet_block" value="Wallet Service&#xa;&#xa;REGISTERED: Trừ ví tự động&#xa;(SELECT FOR UPDATE → trừ tiền)&#xa;&#xa;GUEST: Yêu cầu trả tiền mặt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#ef6c00;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="685" width="200" height="95" as="geometry"/>
        </mxCell>

        <!-- Response to ESP32 -->
        <mxCell id="response" value="HTTP Response → ESP32&#xa;{ action, lcd_line1, lcd_line2 }&#xa;→ Mở barie / Reject" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="820" width="220" height="55" as="geometry"/>
        </mxCell>

        <!-- Gate flow arrows -->
        <mxCell id="g1" value="camera" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CC0000;strokeWidth=1.5;fontSize=9;" edge="1" source="esp_gate" target="cam_handler" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="g2" value="rfid" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CC0000;strokeWidth=1.5;fontSize=9;" edge="1" source="esp_gate" target="rfid_handler" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="g3" value="lưu biển số" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;fontSize=9;" edge="1" source="cam_handler" target="plate_cache" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="g4" value="peek biển số" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;fontSize=9;dashed=1;" edge="1" source="iot_svc" target="plate_cache" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="g5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666;" edge="1" source="rfid_handler" target="iot_svc" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="g6" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666;" edge="1" source="iot_svc" target="gate_type" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="g7" value="ENTRY" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;fontSize=10;fontStyle=1;" edge="1" source="gate_type" target="entry_block" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="g8" value="EXIT" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#ef6c00;fontSize=10;fontStyle=1;" edge="1" source="gate_type" target="exit_block" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="g9" value="trừ tiền" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#ef6c00;fontSize=9;" edge="1" source="exit_block" target="wallet_block" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="g10" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="entry_block" target="response" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="g11" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="wallet_block" target="response" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ========== MYSQL (bottom center) ========== -->
        <mxCell id="mysql_db" value="MySQL" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;size=15;" vertex="1" parent="1">
          <mxGeometry x="350" y="700" width="120" height="70" as="geometry"/>
        </mxCell>

        <!-- DB arrows -->
        <mxCell id="d1" value="UPDATE&#xa;parking_slots" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=1.5;fontSize=9;fontColor=#d6b656;" edge="1" source="batch_update" target="mysql_db" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="280" y="660"/><mxPoint x="280" y="735"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="d2" value="INSERT&#xa;parking_sessions" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=1.5;fontSize=9;fontColor=#d6b656;" edge="1" source="entry_block" target="mysql_db" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="480" y="580"/><mxPoint x="480" y="735"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="d3" value="UPDATE session&#xa;+ wallet" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=1.5;fontSize=9;fontColor=#d6b656;" edge="1" source="wallet_block" target="mysql_db" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="730" y="732"/><mxPoint x="730" y="780"/><mxPoint x="410" y="780"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- ========== LEGEND ========== -->
        <mxCell id="legend_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#ccc;" vertex="1" parent="1">
          <mxGeometry x="280" y="870" width="440" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="leg_t" value="Chú thích" style="text;html=1;fontSize=12;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="290" y="875" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="l1" value="🔴 RAM Cache (lọc, đệm, không ghi DB)" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="290" y="898" width="280" height="16" as="geometry"/>
        </mxCell>
        <mxCell id="l2" value="🟡 Xử lý logic + Ghi DB (chỉ khi cần)" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="290" y="916" width="280" height="16" as="geometry"/>
        </mxCell>
        <mxCell id="l3" value="🟢 Handler / Service (validate, routing)" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="290" y="934" width="280" height="16" as="geometry"/>
        </mxCell>
        <mxCell id="l4" value="🔵 Response / Realtime push" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="540" y="898" width="170" height="16" as="geometry"/>
        </mxCell>
        <mxCell id="l5" value="🟠 Thanh toán (PayOS / Wallet)" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="540" y="916" width="170" height="16" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
