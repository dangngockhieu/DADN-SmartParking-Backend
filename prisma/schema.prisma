generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id            Int            @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String         @unique
  password      String
  username      String         @unique
  role          Role           @default(USER)
  isVerified    Boolean        @default(false)
  code          String?
  expiresAt     DateTime?
  tokens        RefreshToken[]
  slotHistories SlotHistory[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  device    String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "refresh_tokens_userId_fkey")
  @@map("refresh_tokens")
}

model ParkingLot {
  id       Int           @id @default(autoincrement())
  name     String        @db.VarChar(100)
  location String?       @db.VarChar(255)
  devices  IoTDevice[]
  slots    ParkingSlot[]

  @@map("parking_lots")
}

model IoTDevice {
  macAddress String        @id @db.VarChar(50)
  deviceName String?       @db.VarChar(50)
  status     DeviceStatus  @default(ACTIVE)
  lotId      Int?
  lot        ParkingLot?   @relation(fields: [lotId], references: [id])
  slots      ParkingSlot[]

  lastSeen DateTime?

  @@index([lotId])
  @@map("iot_devices")
}

model ParkingSlot {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(10)
  lotId      Int
  deviceMac  String     @db.VarChar(50)
  portNumber Int
  status     SlotStatus @default(AVAILABLE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  device     IoTDevice  @relation(fields: [deviceMac], references: [macAddress])
  lot        ParkingLot @relation(fields: [lotId], references: [id])

  histories SlotHistory[]
  logs      VehicleLog[]

  @@unique([lotId, name])
  @@unique([deviceMac, portNumber])
  @@index([lotId, status])
  @@index([lotId])
  @@index([deviceMac])
  @@map("parking_slots")
}

// Lịch sử thay đổi thiết bị của vị trí đỗ
model SlotHistory {
  id Int @id @default(autoincrement())

  slotId Int

  oldDevice String?
  newDevice String?

  oldPort Int?
  newPort Int?

  action SlotHistoryAction @default(DEVICE_CHANGE)

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  slot ParkingSlot @relation(fields: [slotId], references: [id])

  @@index([slotId])
  @@index([userId])
  @@map("slot_histories")
}

// Lịch sử xe vào ra
model VehicleLog {
  id Int @id @default(autoincrement())

  slotId Int
  type   LogType

  createdAt DateTime @default(now())

  slot ParkingSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@index([slotId])
  @@index([createdAt])
  @@map("vehicle_logs")
}

enum Role {
  USER
  MANAGER
  ADMIN
}

enum SlotStatus {
  AVAILABLE
  OCCUPIED
  MAINTAIN
  OFFLINE
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  ERROR
}

enum SlotHistoryAction {
  DEVICE_CHANGE
  STATUS_CHANGE
  SYSTEM_FIX
  MAINTAIN_MODE
}

enum LogType {
  IN
  OUT
}
