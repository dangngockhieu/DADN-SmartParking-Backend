<mxfile>
  <diagram name="Smart Parking - Upgraded Architecture" id="arch1">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ==================== EDGE LAYER ==================== -->
        <mxCell id="edge_label" value="EDGE LAYER (ESP32)" style="text;html=1;fontSize=16;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="300" height="30" as="geometry"/>
        </mxCell>

        <!-- Sensor Board Group -->
        <mxCell id="sensor_group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="30" y="60" width="340" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="sensor_label" value="ESP32 Sensor Board (x63)" style="text;html=1;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="80" y="70" width="240" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="sr04_1" value="🔊 Cảm biến 1&#xa;(HC-SR04)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="105" width="90" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="sr04_2" value="🔊 Cảm biến 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="155" y="105" width="90" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="sr04_n" value="🔊 ... Cảm biến 8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="105" width="90" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="sensor_task" value="TaskSensorRead&#xa;(FreeRTOS)&#xa;Edge-triggered filter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="175" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="sensor_queue" value="sensorQueue&#xa;(FreeRTOS Queue - RAM)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;size=8;" vertex="1" parent="1">
          <mxGeometry x="130" y="245" width="140" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="mqtt_pub_task" value="MQTT Publish Task&#xa;(fire-and-forget)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="115" y="305" width="170" height="30" as="geometry"/>
        </mxCell>

        <!-- Arrows inside sensor group -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sr04_1" target="sensor_task" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sr04_2" target="sensor_task" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sr04_n" target="sensor_task" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sensor_task" target="sensor_queue" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="sensor_queue" target="mqtt_pub_task" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Gate Board Group -->
        <mxCell id="gate_group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="420" y="60" width="320" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="gate_label" value="ESP32 Gate Board (x20)" style="text;html=1;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="470" y="70" width="220" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="rfid" value="💳 RFID&#xa;(RC522)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="435" y="105" width="85" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="camera" value="📷 Camera&#xa;AI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="535" y="105" width="85" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="actuators" value="🔧 Servo + LCD&#xa;+ RGB LED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="635" y="105" width="85" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="rfid_task" value="TaskRFIDRead&#xa;(FreeRTOS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="180" width="120" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="rfid_queue" value="rfidQueue&#xa;(RAM)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;size=8;" vertex="1" parent="1">
          <mxGeometry x="455" y="240" width="90" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="http_task" value="HTTP POST Task&#xa;(blocking - chờ response)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="300" width="180" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="rfid" target="rfid_task" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="rfid_task" target="rfid_queue" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="rfid_queue" target="http_task" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a_resp" value="response&#xa;→ mở barie" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#CC0000;" edge="1" source="http_task" target="actuators" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="660" y="315"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- ==================== BROKER LAYER ==================== -->
        <mxCell id="broker_label" value="MESSAGE BROKER" style="text;html=1;fontSize=16;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="30" y="370" width="250" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="mqtt_broker" value="MQTT Broker&#xa;(Mosquitto / EMQX)&#xa;&#xa;Lưu message trong RAM&#xa;Gom batch trước khi xử lý" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#7c3aed;fontSize=11;fontStyle=0;size=15;" vertex="1" parent="1">
          <mxGeometry x="80" y="410" width="250" height="100" as="geometry"/>
        </mxCell>

        <!-- Arrow: Sensor → Broker -->
        <mxCell id="a_mqtt" value="MQTT Publish&#xa;(non-blocking ~1ms)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7c3aed;strokeWidth=2;fontColor=#7c3aed;fontSize=10;fontStyle=1;" edge="1" source="mqtt_pub_task" target="mqtt_broker" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== BACKEND LAYER ==================== -->
        <mxCell id="be_label" value="BACKEND (Go / Gin)" style="text;html=1;fontSize=16;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="420" y="370" width="300" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="be_group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#82b366;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="420" y="400" width="380" height="210" as="geometry"/>
        </mxCell>

        <mxCell id="sensor_worker" value="Sensor Worker&#xa;(MQTT Subscribe)&#xa;Batch UPDATE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="435" y="415" width="140" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="iot_handler" value="IoT HTTP Handler&#xa;(Gin - /iot/rfid)&#xa;(Gin - /iot/camera)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="435" y="480" width="140" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="plate_cache" value="PlateCache&#xa;(RAM - sync.Mutex)&#xa;TTL 5 phút" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;size=8;" vertex="1" parent="1">
          <mxGeometry x="600" y="415" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="parking_hub" value="ParkingHub&#xa;(RAM - sync.RWMutex)&#xa;Broadcast realtime" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;size=8;" vertex="1" parent="1">
          <mxGeometry x="600" y="480" width="120" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="wallet_svc" value="Wallet Service&#xa;(Transaction + Lock)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="435" y="550" width="140" height="45" as="geometry"/>
        </mxCell>

        <!-- Arrow: Broker → Worker -->
        <mxCell id="a_sub" value="MQTT Subscribe" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#7c3aed;strokeWidth=2;fontSize=10;fontColor=#7c3aed;" edge="1" source="mqtt_broker" target="sensor_worker" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: Gate HTTP → IoT Handler -->
        <mxCell id="a_http" value="HTTP POST&#xa;(blocking)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CC0000;strokeWidth=2;fontSize=10;fontColor=#CC0000;fontStyle=1;" edge="1" source="http_task" target="iot_handler" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="400" y="315"/><mxPoint x="400" y="507"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- Internal backend arrows -->
        <mxCell id="a_pc" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666;" edge="1" source="iot_handler" target="plate_cache" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a_hub1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666;" edge="1" source="sensor_worker" target="parking_hub" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="580" y="440"/><mxPoint x="580" y="507"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- ==================== DATABASE LAYER ==================== -->
        <mxCell id="db_label" value="DATABASE" style="text;html=1;fontSize=16;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="870" y="370" width="150" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="mysql" value="MySQL&#xa;&#xa;users, parking_sessions,&#xa;parking_slots, rfid_cards,&#xa;wallet_transactions" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;size=15;" vertex="1" parent="1">
          <mxGeometry x="850" y="410" width="190" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="redis" value="Redis&#xa;(Session cache)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;size=10;" vertex="1" parent="1">
          <mxGeometry x="880" y="545" width="130" height="55" as="geometry"/>
        </mxCell>

        <!-- Arrows to DB -->
        <mxCell id="a_db1" value="Batch UPDATE&#xa;parking_slots" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=1.5;fontSize=9;" edge="1" source="sensor_worker" target="mysql" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="810" y="440"/></Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="a_db2" value="INSERT session&#xa;UPDATE wallet" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=1.5;fontSize=9;" edge="1" source="iot_handler" target="mysql" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="505" y="545"/><mxPoint x="820" y="545"/><mxPoint x="820" y="465"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- ==================== REALTIME LAYER ==================== -->
        <mxCell id="wt_server" value="WebTransport&#xa;Server (:4433)&#xa;HTTP/3 Push" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="870" y="640" width="160" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="a_wt" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0284c7;strokeWidth=2;" edge="1" source="parking_hub" target="wt_server" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="660" y="640"/><mxPoint x="660" y="667"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- ==================== FRONTEND ==================== -->
        <mxCell id="frontend" value="Frontend (React + Vite)&#xa;&#xa;📊 Sơ đồ bãi đỗ realtime&#xa;👤 Quản lý user / thẻ / session&#xa;💰 Nạp tiền ví" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="850" y="730" width="200" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="a_fe" value="WebTransport Push&#xa;(realtime)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0284c7;strokeWidth=2;fontSize=9;fontColor=#0284c7;" edge="1" source="wt_server" target="frontend" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a_fe_api" value="HTTP REST API" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666;fontSize=9;" edge="1" source="frontend" target="be_group" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="780" y="780"/><mxPoint x="780" y="610"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- ==================== PAYOS ==================== -->
        <mxCell id="payos" value="💳 PayOS&#xa;Payment Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#ef6c00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="430" y="640" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a_payos" value="Webhook&#xa;+ Payment Link" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#ef6c00;fontSize=9;" edge="1" source="payos" target="wallet_svc" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ==================== LEGEND ==================== -->
        <mxCell id="legend" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#ccc;" vertex="1" parent="1">
          <mxGeometry x="30" y="550" width="340" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="leg_title" value="Chú thích Data Flow" style="text;html=1;fontSize=12;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="555" width="200" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg1" value="── MQTT (non-blocking, ~1ms)" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;fontColor=#7c3aed;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="580" width="250" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="leg2" value="── HTTP (blocking, chờ response)" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;fontColor=#CC0000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="600" width="250" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="leg3" value="── WebTransport (realtime push)" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;fontColor=#0284c7;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="620" width="250" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="leg4" value="── Database query" style="text;html=1;fontSize=10;fillColor=none;strokeColor=none;fontColor=#d6b656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="640" width="250" height="18" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
